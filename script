#!/usr/bin/env python3
"""
Supprime toutes les issues du repo GitHub spécifié via la CLI `gh`.
Repo cible : https://github.com/OpenCz/Wolf3d
"""

import subprocess
import json
import sys


REPO = "OpenCz/Wolf3d"


def run(cmd: list[str]) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, capture_output=True, text=True)


def get_all_issue_numbers(repo: str) -> list[int]:
    """Récupère tous les numéros d'issues (ouvertes + fermées)."""
    result = run([
        "gh", "issue", "list",
        "--repo", repo,
        "--state", "all",
        "--limit", "1000",
        "--json", "number",
    ])

    if result.returncode != 0:
        print(f"Erreur gh : {result.stderr}", file=sys.stderr)
        sys.exit(1)

    issues = json.loads(result.stdout)
    return [issue["number"] for issue in issues]


def delete_issue(repo: str, number: int) -> bool:
    """Supprime une issue via l'API GraphQL de gh."""
    # gh ne propose pas de commande native `gh issue delete` sur toutes les versions ;
    # on passe par l'API REST avec gh api.
    result = run([
        "gh", "api",
        "--method", "DELETE",
        f"/repos/{repo}/issues/{number}",
    ])

    # GitHub ne permet pas la suppression d'issues via REST (403) ;
    # on ferme + verrouille à la place, ce qui est l'équivalent pratique.
    if result.returncode != 0:
        # Fallback : fermer l'issue
        close_result = run([
            "gh", "issue", "close", str(number),
            "--repo", repo,
            "--comment", "Closing as part of bulk cleanup.",
        ])
        return close_result.returncode == 0

    return True


def close_and_lock_issue(repo: str, number: int) -> bool:
    """Ferme et verrouille une issue (équivalent pratique d'une suppression)."""
    # 1. Fermer
    r1 = run(["gh", "issue", "close", str(number), "--repo", repo])
    if r1.returncode != 0:
        print(f"  ✗ Impossible de fermer l'issue #{number} : {r1.stderr.strip()}")
        return False

    # 2. Verrouiller
    r2 = run([
        "gh", "api",
        "--method", "PUT",
        f"/repos/{repo}/issues/{number}/lock",
        "--field", "lock_reason=resolved",
    ])
    # Le verrouillage peut échouer si on n'a pas les droits admin — pas bloquant
    status = "verrouillée" if r2.returncode == 0 else "fermée (verrouillage refusé)"
    print(f"  ✓ Issue #{number} {status}")
    return True


def main():
    print(f"🔍 Récupération des issues du repo {REPO}…")
    numbers = get_all_issue_numbers(REPO)

    if not numbers:
        print("Aucune issue trouvée. Rien à faire.")
        return

    print(f"📋 {len(numbers)} issue(s) trouvée(s) : {numbers}")
    confirm = input("\n⚠️  Confirmer la suppression (fermeture) de toutes ces issues ? [o/N] : ")
    if confirm.strip().lower() not in ("o", "oui", "y", "yes"):
        print("Annulé.")
        return

    print("\n🗑️  Traitement en cours…")
    success = 0
    for number in numbers:
        if close_and_lock_issue(REPO, number):
            success += 1

    print(f"\n✅ Terminé : {success}/{len(numbers)} issue(s) traitée(s).")


if __name__ == "__main__":
    main()